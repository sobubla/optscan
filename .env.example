# .env.example — copy this file to .env and fill in your real values.
# .env is gitignored and must NEVER be committed.
#
# Usage (macOS / Linux):
#   cp .env.example .env
#   # edit .env with your values
#   export $(grep -v '^#' .env | xargs)   # before starting the server
#
# Usage (Windows PowerShell):
#   Copy-Item .env.example .env
#   # edit .env with your values, then set each variable:
#   $env:OPENALGO_BASE_URL = "http://127.0.0.1:8080"
#   $env:OPENALGO_API_KEY  = "your_api_key_here"

# ─── OpenAlgo (required for entry suggestions and exit monitor) ──────────────
# Base URL of your local OpenAlgo server (default port is 8080)
OPENALGO_BASE_URL=http://127.0.0.1:8080

# API key from the OpenAlgo web UI → API Key section
OPENALGO_API_KEY=your_openalgo_api_key_here
